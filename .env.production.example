# ── Public domain (subdomain A record → VPS IP) ─────────────────────────────
DOMAIN="blockforms.yourdomain.com"

# Must use https and match DOMAIN (Caddy terminates TLS on this host)
APP_BASE_URL="https://blockforms.yourdomain.com"
BASE_URL="https://blockforms.yourdomain.com"
CORS_ORIGIN="https://blockforms.yourdomain.com"
NEXT_PUBLIC_API_URL="https://blockforms.yourdomain.com/trpc"

# ── PostgreSQL (internal Docker network) ────────────────────────────────────
POSTGRES_USER="blockforms"
POSTGRES_PASSWORD="change-me-strong-password"
POSTGRES_DB="blockforms"
DATABASE_URL="postgres://blockforms:change-me-strong-password@postgres:5432/blockforms"

# ── Auth ────────────────────────────────────────────────────────────────────
HASHING_ALGORITHM="sha256"
JWT_ACCESS_SECRET="generate-a-long-random-string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="generate-another-long-random-string"
JWT_REFRESH_EXPIRES="7d"
NODE_ENV="production or development"

# ── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=port
SMTP_USER=api
SMTP_PASS="your-smtp-password"
SENDER_EMAIL="noreply@yourdomain.com"

# ── Optional ────────────────────────────────────────────────────────────────
LOGGER_LEVEL=info
