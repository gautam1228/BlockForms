# Replace {$DOMAIN} via docker-compose environment.
# Caddy terminates TLS and routes API paths to the backend, everything else to Next.js.

{$DOMAIN} {
	encode gzip zstd

	handle /trpc* {
		reverse_proxy api:8000
	}

	handle /api* {
		reverse_proxy api:8000
	}

	handle /docs* {
		reverse_proxy api:8000
	}

	handle /openapi.json {
		reverse_proxy api:8000
	}

	handle /health {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}
}
